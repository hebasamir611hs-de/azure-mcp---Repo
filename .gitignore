# Secrets and Sensitive Info — ANY token/credential/PAT file (recursive)
.env
.env.*
!.env.example
mcp-config.json

# MCP registry is per-machine (absolute paths kept ruining pulls — team decision).
# The canonical template is committed as .mcp.json.example; copy it on first clone.
.mcp.json
!.mcp.json.example
**/credentials*.json
**/credentials*.yaml
**/credentials*.yml
**/secrets*.json
**/secrets*.yaml
**/secrets*.yml
*.pat
*.token
.azure-pat
.npmrc
.pypirc
*.pem
*.key
!*.pub.key
service-account*.json
auth*.json


# Environment and Cache
.venv/
__pycache__/
core/__pycache__/
.vscode/
graphify-out/

# Project Artifacts (UAT, Reports, Summaries)
outputs/
unpacked_uat/
scratch/
docs/
# ...except architecture decision records — those are team-facing and reviewed in PRs
!docs/adr-*.md
deliverables/
*.docx
*.pdf
*.log

# Sprint workflow (contains project-specific names)
Run_Sprint_Workflow.py

# Local, machine-specific Claude Code overrides (shared config is settings.json)
.claude/settings.local.json

# Generated test-automation framework — lives at project root, NOT part of this MCP repo.
# Produced on demand by the scaffold-automation-framework skill; never committed here.
automation/
allure-results/
allure-report/
**/videos/
**/screenshots/
playwright-report/
.pytest_cache/

# Microsoft Office temp/lock files
~$*
~WRL*.tmp
*.tmp

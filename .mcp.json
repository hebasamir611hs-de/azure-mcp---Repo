{
  "mcpServers": {
    "azure-devops": {
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "-u",
        "server.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "appium": {
      "command": "npx",
      "args": [
        "-y",
        "appium-mcp@latest"
      ]
    }
  }
}

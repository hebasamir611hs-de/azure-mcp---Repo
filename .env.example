# Template — copy to .env (git-ignored) on first clone: cp .env.example .env
# Every value the MCP server and the Phase-1 analysis read. Fill per machine.

# --- Azure DevOps (required) ---
AZURE_PAT=your-azure-devops-personal-access-token
AZURE_ORG_URL=https://dev.azure.com/your-org
AZURE_PROJECT=your-project-name

# --- Phase-1 input sources (optional — leave empty if unused) ---
# Used only when a PBI references a locked source; see CLAUDE.md Core stance.
FIGMA_TOKEN=
ATTACHMENTS_TOKEN=

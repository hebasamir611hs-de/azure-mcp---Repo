{
  "_comment": "Canonical MCP registry. Copy to .mcp.json (git-ignored) on first clone: cp .mcp.json.example .mcp.json — keep paths RELATIVE; never commit machine-specific absolute paths.",
  "mcpServers": {
    "azure-devops": {
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "-u",
        "server.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "appium": {
      "command": "npx",
      "args": [
        "-y",
        "appium-mcp@1.87.6"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.78"
      ]
    }
  }
}
